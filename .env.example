# --- API ---
ENVIRONMENT=development
SECRET_KEY=replace-with-a-32+char-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Database ---
# Local docker-compose Postgres:
DATABASE_URL=postgresql+asyncpg://finstream:finstream@localhost:5432/finstream

# --- CORS (comma-separated; JSON list also accepted) ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Snowflake (optional: set all to offload analytics to Snowflake) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=FINSTREAM_WH
SNOWFLAKE_DATABASE=FINSTREAM
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_ROLE=FINSTREAM_ANALYST
